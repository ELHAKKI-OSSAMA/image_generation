// Image Generation B2B Platform Database Schema
// Schema name: img_gen
// Description: Database for managing organizations, events, and AI-generated images

//-----------------
// CORE ENTITIES
//-----------------

// Primary table for business clients
Table client {
  id UUID [pk, default: `uuid_generate_v4()`]
  name varchar(255) [not null]
  status varchar(50) [not null, default: 'pending']
  created_at timestamptz [not null, default: `CURRENT_TIMESTAMP`]
  updated_at timestamptz [not null, default: `CURRENT_TIMESTAMP`]
  subscription_tier varchar(50) [not null, default: 'trial']
  max_users integer [not null, default: 5]
  max_storage_gb integer [not null, default: 10]

  indexes {
    name
    status
  }

  note: 'Core table for B2B organizations'
}

// Organization staff members
Table member {
  id UUID [pk, default: `uuid_generate_v4()`]
  organization_id UUID [not null]
  email varchar(255) [unique, not null]
  password_hash varchar(255) [not null]
  first_name varchar(100)
  last_name varchar(100)
  role varchar(50) [not null, default: 'staff']
  status varchar(50) [not null, default: 'pending']
  created_at timestamptz [not null, default: `CURRENT_TIMESTAMP`]
  updated_at timestamptz [not null, default: `CURRENT_TIMESTAMP`]
  last_login timestamptz

  indexes {
    email
    organization_id
    (organization_id, role)
  }

  note: 'Organization members (admins and staff)'
}

//-----------------
// EVENT MANAGEMENT
//-----------------

// Events where images are generated
Table event {
  id UUID [pk, default: `uuid_generate_v4()`]
  organization_id UUID [not null]
  name varchar(255) [not null]
  description text
  start_date timestamptz [not null]
  end_date timestamptz [not null]
  status varchar(50) [not null, default: 'upcoming']
  created_at timestamptz [not null, default: `CURRENT_TIMESTAMP`]
  updated_at timestamptz [not null, default: `CURRENT_TIMESTAMP`]
  created_by UUID [not null]
  max_participants integer
  location varchar(255)

  indexes {
    organization_id
    status
    start_date
    created_by
  }

  note: 'Photo session events'
}

// Images generated during events
Table image {
  id UUID [pk, default: `uuid_generate_v4()`]
  event_id UUID [not null]
  created_by UUID [not null]
  original_url text [not null]
  generated_url text [not null]
  prompt text
  status varchar(50) [not null, default: 'processing']
  created_at timestamptz [not null, default: `CURRENT_TIMESTAMP`]
  updated_at timestamptz [not null, default: `CURRENT_TIMESTAMP`]
  metadata jsonb
  processing_time integer

  indexes {
    event_id
    created_by
    status
    created_at
  }

  note: 'Original and AI-generated images'
}

// Event attendees (temporary users)
Table attendee {
  id UUID [pk, default: `uuid_generate_v4()`]
  event_id UUID [not null]
  organization_id UUID [not null]
  name varchar(255) [not null]
  email varchar(255)
  phone varchar(50)
  registration_code varchar(100) [unique]
  check_in_time timestamptz
  check_out_time timestamptz
  created_at timestamptz [not null, default: `CURRENT_TIMESTAMP`]
  created_by UUID [not null]

  indexes {
    event_id
    organization_id
    registration_code
    email
  }

  note: 'Event attendees who can take photos'
}

//-----------------
// SECURITY & MONITORING
//-----------------

// API authentication keys
Table key {
  id UUID [pk, default: `uuid_generate_v4()`]
  organization_id UUID [not null]
  key_hash varchar(255) [not null]
  name varchar(100) [not null]
  created_by UUID [not null]
  expires_at timestamptz
  created_at timestamptz [not null, default: `CURRENT_TIMESTAMP`]
  last_used_at timestamptz
  status varchar(50) [not null, default: 'active']

  indexes {
    organization_id
    key_hash
    status
  }

  note: 'API access keys'
}

// Usage tracking and billing
Table stat {
  id UUID [pk, default: `uuid_generate_v4()`]
  organization_id UUID [not null]
  event_id UUID
  date date [not null, default: `CURRENT_DATE`]
  images_generated integer [not null, default: 0]
  storage_used_bytes bigint [not null, default: 0]
  api_calls integer [not null, default: 0]
  created_at timestamptz [not null, default: `CURRENT_TIMESTAMP`]
  updated_at timestamptz [not null, default: `CURRENT_TIMESTAMP`]

  indexes {
    organization_id
    date
    (organization_id, date)
  }

  note: 'Resource usage tracking'
}

// Security audit trail
Table log {
  id UUID [pk, default: `uuid_generate_v4()`]
  organization_id UUID [not null]
  user_id UUID
  action varchar(100) [not null]
  resource_type varchar(50) [not null]
  resource_id UUID
  details jsonb
  ip_address inet
  user_agent text
  created_at timestamptz [not null, default: `CURRENT_TIMESTAMP`]

  indexes {
    organization_id
    user_id
    created_at
    action
  }

  note: 'Security audit trail'
}

// Access requests from organizations
Table request {
  id UUID [pk, default: `uuid_generate_v4()`]
  organization_id UUID [not null]
  status varchar(50) [not null, default: 'pending']
  request_type varchar(50) [not null, default: 'demo']
  contact_name varchar(255) [not null]
  contact_email varchar(255) [not null]
  contact_phone varchar(50)
  notes text
  reviewed_by UUID
  reviewed_at timestamptz
  created_at timestamptz [not null, default: `CURRENT_TIMESTAMP`]
  updated_at timestamptz [not null, default: `CURRENT_TIMESTAMP`]

  indexes {
    organization_id
    status
    contact_email
  }

  note: 'Organization access and demo requests'
}

//-----------------
// USER MANAGEMENT
//-----------------

// System administrators (developers)
Table admin {
  id UUID [pk, default: `uuid_generate_v4()`]
  email varchar(255) [unique, not null]
  password_hash varchar(255) [not null]
  first_name varchar(100)
  last_name varchar(100)
  status varchar(50) [not null, default: 'active']
  created_at timestamptz [not null, default: `CURRENT_TIMESTAMP`]
  updated_at timestamptz [not null, default: `CURRENT_TIMESTAMP`]
  last_login timestamptz

  indexes {
    email
    status
  }

  note: 'System administrators who manage the platform'
}

// User sessions for all user types
Table session {
  id UUID [pk, default: `uuid_generate_v4()`]
  admin_id UUID
  member_id UUID
  attendee_id UUID
  event_id UUID
  organization_id UUID [not null]
  session_token varchar(255) [not null]
  ip_address inet
  user_agent text
  expires_at timestamptz [not null]
  created_at timestamptz [not null, default: `CURRENT_TIMESTAMP`]
  last_activity timestamptz [not null, default: `CURRENT_TIMESTAMP`]

  indexes {
    session_token
    admin_id
    member_id
    attendee_id
    expires_at
  }

  note: 'Active sessions for all user types'
}

//-------------------
// RELATIONSHIPS
//-------------------

// Organization references
Ref: member.organization_id > client.id [delete: cascade]
Ref: event.organization_id > client.id [delete: cascade]
Ref: key.organization_id > client.id [delete: cascade]
Ref: stat.organization_id > client.id [delete: cascade]
Ref: log.organization_id > client.id
Ref: request.organization_id > client.id [delete: cascade]
Ref: session.organization_id > client.id [delete: cascade]
Ref: image.organization_id > client.id

// User references
Ref: event.created_by > member.id
Ref: image.created_by > member.id
Ref: key.created_by > member.id
Ref: attendee.created_by > member.id

Ref: request.reviewed_by > admin.id

Ref: attendee.event_id > event.id [delete: cascade]

Ref: session.admin_id > admin.id [delete: cascade]
Ref: session.member_id > member.id [delete: cascade]
Ref: session.attendee_id > attendee.id [delete: cascade]
Ref: session.event_id > event.id

Ref: log.user_id > member.id

Ref: image.event_id > event.id [delete: cascade]
Ref: stat.event_id > event.id

//-------------------
// VISUALIZATION GROUPS
//-------------------

TableGroup Management {
  client
  member
}

TableGroup Generation {
  event
  attendee
  image
}

TableGroup Security {
  key
  session
  log
  stat
  request
}
