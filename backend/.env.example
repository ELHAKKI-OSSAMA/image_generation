# Backend environment configuration.
# Copy this file to `.env` (which is git-ignored) and fill in real values.

# ---- Application ----
APP_PORT=8000
# Set to "production" to make Redis mandatory and tighten behaviour.
ENV=development
# CORS allow-list. Parsed with ast.literal_eval, so it MUST be a valid Python list literal.
ALLOWED_HOSTS=["http://localhost:5173"]

# ---- PostgreSQL ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ofotolab

# ---- JWT ----
# Use a long, random secret in any real deployment.
SECRET_KEY=change-me-to-a-long-random-string

# ---- Redis (optional in development, required when ENV=production) ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ---- Email / SMTP (optional, only needed for verification e-mails) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=Ofotolab <your-email@gmail.com>
